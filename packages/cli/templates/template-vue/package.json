{
    "name": "vite-vue-team-starter",
    "private": true,
    "version": "0.0.0",
    "description": "Team standardized Vue + Vite starter template",
    "license": "MIT",
    "packageManager": "pnpm@9.7.0",
    "engines": {
        "node": ">=20",
        "pnpm": ">=9"
    },
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint:vue": "eslint .",
        "lint:css": "stylelint \"**/*.{css,scss,vue}\"",
        "lint:staged": "lint-staged",
        "lint": "pnpm lint:vue && pnpm lint:css",
        "format": "prettier --write .",
        "spellcheck": "cspell lint --dot --gitignore --color --cache --show-suggestions \"**/*.@(html|js|cjs|mjs|ts|tsx|css|scss|md|vue)\"",
        "check": "pnpm lint && pnpm spellcheck",
        "commit": "git-cz",
        "prepare": "husky"
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-git"
        }
    },
    "lint-staged": {
        "*.{md,json}": [
            "prettier --cache --write --no-error-on-unmatched-pattern"
        ],
        "*.{css,less,scss,vue}": [
            "stylelint --fix",
            "prettier --cache --write"
        ],
        "*.{js,jsx}": [
            "eslint --fix",
            "prettier --cache --write"
        ]
    },
    "dependencies": {
        "vue": "^3.4.37"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^5.1.2",
        "@eslint/js": "9.37.0",
        "@commitlint/cli": "20.1.0",
        "@commitlint/config-conventional": "20.0.0",
        "commitizen": "4.3.1",
        "cspell": "9.2.1",
        "cz-git": "1.12.0",
        "eslint": "9.37.0",
        "eslint-plugin-simple-import-sort": "12.1.1",
        "eslint-plugin-vue": "10.5.0",
        "globals": "16.4.0",
        "husky": "9.1.7",
        "lint-staged": "16.2.4",
        "prettier": "3.6.2",
        "stylelint": "16.25.0",
        "stylelint-config-standard": "39.0.1",
        "stylelint-config-standard-scss": "16.0.0",
        "stylelint-config-standard-vue": "1.0.0",
        "vite": "^5.4.1",
        "vue-eslint-parser": "10.2.0"
    }
}
