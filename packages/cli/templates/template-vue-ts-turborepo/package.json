{
    "name": "miao-vue-ts-turborepo",
    "version": "1.0.0",
    "description": "Team standardized Vue + Vite + TypeScript Turborepo template",
    "license": "MIT",
    "packageManager": "pnpm@9.7.0",
    "engines": {
        "node": ">=20",
        "pnpm": ">=9"
    },
    "type": "module",
    "scripts": {
        "dev": "turbo run dev --parallel",
        "build": "turbo run build",
        "lint": "turbo run lint",
        "check": "pnpm lint && pnpm spellcheck",
        "lint:staged": "lint-staged",
        "format": "prettier --write .",
        "spellcheck": "cspell lint --dot --gitignore --color --cache --show-suggestions \"(packages|apps)/**/*.@(html|js|cjs|mjs|ts|tsx|css|scss|md|vue)\"",
        "commit": "git-cz",
        "prepare": "husky"
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-git"
        }
    },
    "lint-staged": {
        "*.{md,json}": [
            "prettier --cache --write --no-error-on-unmatched-pattern"
        ],
        "*.{css,less,scss,vue}": [
            "stylelint --fix",
            "prettier --cache --write"
        ],
        "*.{js,jsx}": [
            "eslint --fix",
            "prettier --cache --write"
        ],
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write --cache --parser=typescript"
        ],
        "*.vue": [
            "eslint --fix",
            "prettier --cache --write"
        ]
    },
    "devDependencies": {
        "@commitlint/cli": "20.1.0",
        "@commitlint/config-conventional": "20.0.0",
        "@eslint/js": "9.37.0",
        "@typescript-eslint/parser": "8.46.0",
        "commitizen": "4.3.1",
        "commitlint": "20.1.0",
        "cspell": "9.2.1",
        "cz-git": "1.12.0",
        "eslint": "9.37.0",
        "eslint-plugin-simple-import-sort": "12.1.1",
        "eslint-plugin-vue": "10.5.0",
        "globals": "16.4.0",
        "husky": "9.1.7",
        "lint-staged": "16.2.4",
        "prettier": "3.6.2",
        "stylelint": "16.25.0",
        "stylelint-config-standard": "39.0.1",
        "stylelint-config-standard-scss": "16.0.0",
        "stylelint-config-standard-vue": "1.0.0",
        "turbo": "2.0.12",
        "typescript": "5.9.3",
        "vue-eslint-parser": "10.2.0"
    }
}
