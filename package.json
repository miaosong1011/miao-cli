{
    "name": "miao-cli",
    "version": "0.0.1",
    "description": "Enterprise-ready scaffolding monorepo for miao CLI",
    "packageManager": "pnpm@9.7.0",
    "pnpm": {
        "ignoreMissing": [
            "*"
        ]
    },
    "main": "index.js",
    "scripts": {
        "dev": "turbo run dev",
        "build": "turbo run build",
        "test": "pnpm --filter @miao/cli test",
        "changeset": "changeset",
        "version:packages": "changeset version",
        "publish:packages": "pnpm release:check && changeset publish",
        "audit": "pnpm audit --prod --audit-level high",
        "preflight": "pnpm lint && pnpm typecheck && pnpm test && pnpm --filter @miao/cli build",
        "release:check": "pnpm preflight && pnpm --filter @miao/cli release:check",
        "release": "pnpm publish:packages",
        "lint": "eslint \"{packages,apps}/**/*.{js,jsx,ts,tsx}\"",
        "lint:staged": "lint-staged --config .lintstagedrc.cjs",
        "spellcheck": "cspell lint --dot --gitignore --color --cache --show-suggestions \"(packages|apps)/**/*.@(html|js|cjs|mjs|ts|tsx|css|scss|md)\"",
        "typecheck": "tsc --noEmit",
        "graph": "madge --extensions ts --ts-config tsconfig.json packages/*/src",
        "commit": "git-cz",
        "prepare": "husky"
    },
    "keywords": [],
    "author": "miaosong",
    "license": "MIT",
    "config": {
        "commitizen": {
            "path": "node_modules/cz-git"
        }
    },
    "devDependencies": {
        "@types/node": "22.2.0",
        "@types/jest": "29.5.12",
        "typescript": "5.5.4",
        "eslint": "9.9.0",
        "@eslint/js": "9.9.0",
        "cspell": "8.13.3",
        "globals": "15.9.0",
        "typescript-eslint": "8.1.0",
        "@typescript-eslint/eslint-plugin": "8.1.0",
        "eslint-plugin-simple-import-sort": "12.1.1",
        "lint-staged": "15.2.9",
        "prettier": "3.3.3",
        "@commitlint/cli": "19.4.0",
        "@commitlint/config-conventional": "19.2.2",
        "commitizen": "4.3.0",
        "husky": "9.1.4",
        "cz-git": "1.9.4",
        "madge": "8.0.0",
        "turbo": "2.0.12",
        "@changesets/cli": "2.28.1"
    }
}
